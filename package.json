{
  "name": "@notion-skill/core",
  "version": "1.0.0",
  "description": "Reflect repositories into Notion and integrate with Linear tracks",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "notion-sync": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/* tests/**/*",
    "lint:fix": "eslint src/**/* tests/**/* --fix",
    "format": "prettier --write \"src/**/*\" \"tests/**/*\"",
    "sync:adapters": "python scripts/sync_adapters.py",
    "validate:tracks": "python scripts/validate_tracks.py",
    "reflect:repo": "python scripts/reflect_repo.py"
  },
  "keywords": [
    "notion",
    "linear",
    "git",
    "repository",
    "conductor",
    "tracks",
    "sync",
    "integration"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@notionhq/client": "^2.2.15",
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0",
    "axios": "^1.6.8",
    "yaml": "^2.4.2",
    "zod": "^3.23.8",
    "simple-git": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/jest": "^29.5.12",
    "@types/fs-extra": "^11.0.4",
    "@typescript-eslint/eslint-plugin": "^7.7.1",
    "@typescript-eslint/parser": "^7.7.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
