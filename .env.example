# Notion API Configuration
NOTION_API_KEY=your_notion_api_key_here
NOTION_REPOSITORIES_DB_ID=your_repositories_database_id
NOTION_TRACKS_DB_ID=your_tracks_database_id
NOTION_LINEAR_PROJECTS_DB_ID=your_linear_projects_database_id

# Linear API Configuration
LINEAR_API_KEY=your_linear_api_key_here
LINEAR_MCP_ENDPOINT=https://mcp.linear.app/sse

# Sync Configuration
SYNC_FREQUENCY=on-commit
INCLUDE_ARCHIVED_TRACKS=true
SYNC_LINEAR_ISSUES=true
SYNC_CYCLES=false

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/notion-sync.log
